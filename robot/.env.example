# Copy to .env and fill in. `lk app env -w -d .env` fills the LIVEKIT_* ones.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# Shared room name — must match what Advaita subscribes to.
LIVEKIT_ROOM=baymax-robot

# Optional
PORTAL_FPS=30
WEBCAM_INDEX=0
LOG_LEVEL=INFO
