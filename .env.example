# Copy to .env and fill in values. Never commit .env.
# A single root .env serves the whole pipeline: it is loaded by the agents
# (agents/shared/config.py calls load_dotenv()) and by the robot processes
# (robot/_common.load_env() also checks this directory).

# --- LLM ---------------------------------------------------------------
# Gemini powers every Band agent (agents/shared/llm.py -> gemini-2.5-flash)
# and the Vision Agent's scene description. This is the one required LLM key.
GEMINI_API_KEY=...

# Optional: route the agent fleet through Nebius AI Studio (OpenAI-compatible,
# GPU-hosted open models) instead of Gemini. Set LLM_PROVIDER=nebius to enable.
# LLM_PROVIDER=gemini
# NEBIUS_API_KEY=...
# NEBIUS_MODEL=meta-llama/Llama-3.3-70B-Instruct
# NEBIUS_BASE_URL=https://api.studio.nebius.com/v1/

# --- LiveKit -----------------------------------------------------------
# The camera publisher and the Vision Agent each mint a token from the key/
# secret below, scoped to LIVEKIT_ROOM. All processes MUST share one room name
# or the camera track is invisible to the Vision Agent.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret
LIVEKIT_ROOM=baymax-robot
# Optional: supply a pre-minted token instead of key/secret (Vision Agent only).
# LIVEKIT_TOKEN=

# --- Band --------------------------------------------------------------
# Each agent has its own ID + API key from the Band dashboard. IDs/keys are
# REQUIRED (read via os.environ[...] in agents/shared/config.py and
# vision_agent.py). Handles are OPTIONAL — they have working defaults; only
# override if your Band workspace namespace differs from the defaults.
ConductorID=...
ConductorBandAPI=...
# ConductorHandle=@your-workspace/conductor
UpperleftID=...
UpperleftBandAPI=...
# UpperleftHandle=@your-workspace/upperleft
UpperRightID=...
UpperRightBandAPI=...
# UpperRightHandle=@your-workspace/upperright
LowerID=...
LowerBandAPI=...
# LowerHandle=@your-workspace/lower
ThreatID=...
ThreatBandAPI=...
# ThreatHandle=@your-workspace/threat
SpineID=...
SpineBandAPI=...
# SpineHandle=@your-workspace/spine
SafetyID=...
SafetyBandAPI=...
# SafetyHandle=@your-workspace/safety
VisionID=...
VisionBandAPI=...
# VisionHandle=@your-workspace/vision
RobotID=...
RobotBandAPI=...
# RobotHandle=@your-workspace/robot

# --- Tunables (sane defaults; override only if needed) -----------------
# BAYMAX_SPEED   gait speed multiplier    (default 1.0; 1.2 faster, 0.8 safer)
# WEBCAM_INDEX   capture device index     (default 0; try 1/2 if 0 fails)
# LOG_LEVEL      INFO / DEBUG / WARNING    (default INFO)
LOG_LEVEL=INFO
