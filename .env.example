# Copy to .env and fill in values. Never commit .env.
# ONE root .env for the whole team: loaded by the agents (agents/shared/config.py
# calls load_dotenv()) AND by the robot processes (robot/_common.load_env checks
# this directory too).
#
# Who needs what:
#   Band agents (conductor/upper_left/upper_right/lower/threat/spine)
#       -> GEMINI_API_KEY + that agent's <Name>ID / <Name>BandAPI
#   Vision Agent (agents/vision_agent.py)
#       -> GEMINI_API_KEY + VisionID/VisionBandAPI + LIVEKIT_*
#   Robot publisher (robot/webcam_publish.py | robot/robot.py)
#       -> LIVEKIT_URL + LIVEKIT_API_KEY + LIVEKIT_API_SECRET + LIVEKIT_ROOM
#   Standalone Claude conductor (agents/conductor_agent.py, optional TTS path)
#       -> ANTHROPIC_API_KEY

# --- LLM ---------------------------------------------------------------
# Gemini powers EVERY Band agent (agents/shared/llm.py -> gemini-2.5-flash)
# and the Vision Agent's scene description. This is the one required LLM key.
GEMINI_API_KEY=...
# Only needed if you run the standalone conductor_agent.py (Claude + macOS TTS).
# The core Band pipeline does NOT need this.
ANTHROPIC_API_KEY=sk-ant-...

# --- LiveKit (Adil owns) ----------------------------------------------
# Robot publisher and Vision Agent each mint their own token from the
# key/secret below, scoped to LIVEKIT_ROOM. Everyone MUST use the same
# room name or the camera track is invisible to the Vision Agent.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret
LIVEKIT_ROOM=baymax-robot
# Optional: supply a pre-minted token instead of key/secret (Vision Agent only).
# LIVEKIT_TOKEN=

# --- Band (Eshwar owns) -----------------------------------------------
# Each agent has its own ID + API key from the band.ai dashboard.
# IDs/keys are REQUIRED (read via os.environ[...] in agents/shared/config.py
# and vision_agent.py). Handles are OPTIONAL — they have working defaults;
# only override if your Band namespace differs from the defaults shown.
ConductorID=...
ConductorBandAPI=...
# ConductorHandle=@eshwar.rajasekar/conductor
UpperleftID=...
UpperleftBandAPI=...
# UpperleftHandle=@eshwar.rajasekar/upperleft
UpperRightID=...
UpperRightBandAPI=...
# UpperRightHandle=@eshwar.rajasekar/upperright
LowerID=...
LowerBandAPI=...
# LowerHandle=@eshwar.rajasekar/lower
ThreatID=...
ThreatBandAPI=...
# ThreatHandle=@eshwar.rajasekar/threat
SpineID=...
SpineBandAPI=...
# SpineHandle=@eshwar.rajasekar/spine
VisionID=...
VisionBandAPI=...
# VisionHandle=@eshwar.rajasekar/vision
RobotID=...
RobotBandAPI=...
# RobotHandle=@eshwar.rajasekar/robot
SafetyID=...
SafetyBandAPI=...
# SafetyHandle=@eshwar.rajasekar/safety
DashboardID=...
DashboardBandAPI=...
# DashboardHandle=@eshwar.rajasekar/dashboard

# --- Nebius (Advaita owns — UFB compute platform) ---------------------
# NOT read by any code in this repo. Nebius is the GPU compute / Physical AI
# Workbench host (required for the UFB track; $150 credit via UFB Slack) and
# where the Booster K1 simulator runs. Document your key here for the team;
# it's consumed by the Nebius console/CLI/sim, not the agent pipeline.
# NEBIUS_API_KEY=

# --- Optional tunables -------------------------------------------------
# PORTAL_FPS   camera publish rate      (default 30)
# WEBCAM_INDEX which camera to capture  (default 0; try 1/2 if 0 fails)
# LOG_LEVEL    INFO / DEBUG / WARNING   (default INFO)
PORTAL_FPS=30
WEBCAM_INDEX=0
LOG_LEVEL=INFO

# --- Not required ------------------------------------------------------
# Arize Phoenix runs locally with NO API key (pip install arize-phoenix).
