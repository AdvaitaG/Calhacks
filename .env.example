# Copy to .env and fill in values. Never commit .env.
# This single root .env is loaded by the agents AND by robot/robot.py
# (its loader checks this directory too). One file for the whole team.

# --- LLM ---------------------------------------------------------------
# Project standard is Gemini (see project_context.md). NOTE: vision_agent.py
# currently still uses Anthropic Claude — open decision, see the team.
GEMINI_API_KEY=...
ANTHROPIC_API_KEY=sk-ant-...

# --- LiveKit (Adil owns) ----------------------------------------------
# Agents mint their own tokens from the key/secret below, scoped to
# LIVEKIT_ROOM. Everyone MUST use the same room name or the camera track
# is invisible to the Vision Agent.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret
LIVEKIT_ROOM=baymax-robot
# Optional override: a pre-minted token (otherwise minted from key/secret)
# LIVEKIT_TOKEN=

# --- Band (Eshwar owns) -----------------------------------------------
BAND_API_KEY=...
BAND_ROOM=baymax-coordination

# --- Optional ----------------------------------------------------------
PORTAL_FPS=30
WEBCAM_INDEX=0
LOG_LEVEL=INFO
