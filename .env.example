# Copy to .env and fill in values. Never commit .env.
# This single root .env is loaded by the agents AND by robot/robot.py
# (its loader checks this directory too). One file for the whole team.

# --- LLM ---------------------------------------------------------------
# Project standard is Gemini (see project_context.md). NOTE: vision_agent.py
# currently still uses Anthropic Claude — open decision, see the team.
GEMINI_API_KEY=...
ANTHROPIC_API_KEY=sk-ant-...

# --- LiveKit (Adil owns) ----------------------------------------------
# Agents mint their own tokens from the key/secret below, scoped to
# LIVEKIT_ROOM. Everyone MUST use the same room name or the camera track
# is invisible to the Vision Agent.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret
LIVEKIT_ROOM=baymax-robot
# Optional override: a pre-minted token (otherwise minted from key/secret)
# LIVEKIT_TOKEN=

# --- Band (Eshwar owns) -----------------------------------------------
# Each agent has its own ID + API key from band.ai dashboard.
# ConductorID / ConductorBandAPI, etc. are read by agents/shared/config.py
ConductorID=...
ConductorBandAPI=...
ConductorHandle=@eshwar.rajasekar/conductor
UpperleftID=...
UpperleftBandAPI=...
UpperleftHandle=@eshwar.rajasekar/upperleft
UpperRightID=...
UpperRightBandAPI=...
UpperRightHandle=@eshwar.rajasekar/upperright
LowerID=...
LowerBandAPI=...
LowerHandle=@eshwar.rajasekar/lower
ThreatID=...
ThreatBandAPI=...
ThreatHandle=@eshwar.rajasekar/threat
SpineID=...
SpineBandAPI=...
SpineHandle=@eshwar.rajasekar/spine
VisionID=...
VisionBandAPI=...
VisionHandle=@eshwar.rajasekar/vision
SafetyHandle=@matthew.../safety

# --- Optional ----------------------------------------------------------
PORTAL_FPS=30
WEBCAM_INDEX=0
LOG_LEVEL=INFO
